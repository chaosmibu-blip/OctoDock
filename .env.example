# Database
DATABASE_URL=postgresql://user:password@localhost:5432/agentdock

# NextAuth
NEXTAUTH_SECRET=your-nextauth-secret
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (AgentDock user login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Token encryption (32 bytes hex)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=

# Notion OAuth
NOTION_OAUTH_CLIENT_ID=
NOTION_OAUTH_CLIENT_SECRET=

# Gmail OAuth (separate from Google login credentials)
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=

# Meta OAuth (Phase 2)
META_OAUTH_CLIENT_ID=
META_OAUTH_CLIENT_SECRET=

# OpenAI Embedding API (for pgvector semantic search)
# Optional: if not set, memory search falls back to text matching
OPENAI_EMBEDDING_API_KEY=
