# ============================================================
# OctoDock 環境變數
# 複製此檔為 .env 並填入你的值
# ============================================================

# Database（docker compose 已預設，自架時改成你的）
DATABASE_URL=postgresql://user:password@localhost:5432/octodock

# NextAuth（用戶登入 session 加密）
NEXTAUTH_SECRET=your-nextauth-secret
NEXTAUTH_URL=http://localhost:3000

# Google OAuth（OctoDock 用戶登入用）
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Token 加密金鑰（32 bytes hex，所有 OAuth token 用 AES-256-GCM 加密）
# 產生方式: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=

# ── App OAuth 憑證（依需要填入）──

# Notion
NOTION_OAUTH_CLIENT_ID=
NOTION_OAUTH_CLIENT_SECRET=

# Gmail（獨立於 Google 登入的 OAuth App）
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=

# Meta（Threads + Instagram 共用）
META_OAUTH_CLIENT_ID=
META_OAUTH_CLIENT_SECRET=

# Google Calendar
GCAL_OAUTH_CLIENT_ID=
GCAL_OAUTH_CLIENT_SECRET=

# Google Drive
GDRIVE_OAUTH_CLIENT_ID=
GDRIVE_OAUTH_CLIENT_SECRET=

# Google Sheets
GSHEETS_OAUTH_CLIENT_ID=
GSHEETS_OAUTH_CLIENT_SECRET=

# Google Tasks
GTASKS_OAUTH_CLIENT_ID=
GTASKS_OAUTH_CLIENT_SECRET=

# YouTube
YOUTUBE_OAUTH_CLIENT_ID=
YOUTUBE_OAUTH_CLIENT_SECRET=

# Google Docs
GDOCS_OAUTH_CLIENT_ID=
GDOCS_OAUTH_CLIENT_SECRET=

# GitHub（注意：跟 GOOGLE_CLIENT_ID 用於登入的不同）
GITHUB_APP_OAUTH_CLIENT_ID=
GITHUB_APP_OAUTH_CLIENT_SECRET=

# Todoist OAuth（從 developer.todoist.com/appconsole.html 建立 App）
TODOIST_CLIENT_ID=
TODOIST_CLIENT_SECRET=

# Microsoft 365（Word / Excel / PowerPoint 共用）
# Azure Portal → Microsoft Entra ID → App registrations
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Canva Connect API
CANVA_CLIENT_ID=
CANVA_CLIENT_SECRET=

# Telegram Client API（MTProto，用戶帳號操作）
# 從 https://my.telegram.org → API development tools 取得
TG_API_ID=
TG_API_HASH=

# 反饋通知信箱（FormSubmit.co，不設定則只存 DB 不寄信）
FEEDBACK_EMAIL=

# Notion Blog 資料庫 ID（/blog 頁面用）
NOTION_BLOG_DATABASE_ID=

# ── 可選 ──

# OpenAI Embedding API（pgvector 語意搜尋用）
# 不設定的話記憶搜尋退回文字比對
OPENAI_EMBEDDING_API_KEY=

# Anthropic API（排程引擎的內部 AI 用）
# 不設定的話 SOP/AI 類型排程無法執行
ANTHROPIC_API_KEY=

# 排程引擎觸發 API 的驗證 secret
# 設定後外部 cron job 需帶 Authorization: Bearer {secret}
SCHEDULER_SECRET=

# Paddle 收款（網站訂閱）
PADDLE_WEBHOOK_SECRET=
PADDLE_API_KEY=
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
NEXT_PUBLIC_PADDLE_ENV=sandbox
NEXT_PUBLIC_PADDLE_PRO_MONTHLY_PRICE_ID=
NEXT_PUBLIC_PADDLE_PRO_YEARLY_PRICE_ID=

# 綠界 ECPay 收款（台灣企業）
ECPAY_MERCHANT_ID=
ECPAY_HASH_KEY=
ECPAY_HASH_IV=
